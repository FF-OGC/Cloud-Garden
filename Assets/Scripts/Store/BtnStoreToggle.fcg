import "StdLibrary.fcc" as std
import "Hud.fcc" as hud
import "EditorGenLib.fcc" as gen

[platform_client]
graph BtnStoreToggle {

    event OnTapped(player entity<Player>) {
        LogInfo("[BtnStoreToggle] Player tapped store toggle")
        DispatchEventToEntity(OnPlayerToggleStore, globalEntity, PlatformType.Server, List<object>{player})
    }
}
