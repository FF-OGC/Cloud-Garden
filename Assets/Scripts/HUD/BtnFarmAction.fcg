graph BtnFarmAction {
    
    event OnTapped(player entity<Player>) {
        // Broadcast user input event to the logic controllers
        DispatchEvent(gen.OnPlayerHoeAction, globalEntity, List<object>{player as entity<Entity>})
    }
}