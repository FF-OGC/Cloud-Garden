import "StdLibrary.fcc" as std
import "Map.fcc" as map

graph FloorGridData {
    CellStates Map<string, int> 
    PotTiers Map<string, int>   
    
    // SEPARATED VISUAL STORAGE
    PotVisuals Map<string, entity<Entity>>    // Stores the Pot entities
    PlantVisuals Map<string, entity<Entity>>  // Stores the Plant/Seed entities

    event OnAwake() {
        CellStates = map.New()
        PotTiers = map.New()
        PotVisuals = map.New()
        PlantVisuals = map.New()
    }
}